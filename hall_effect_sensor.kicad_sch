	(text "Feedback\n\nR1 = 1/((1/10k)+1/(1/10M)) = 9,99 kohm\nR1 to Vcc\nVref = R2/(R1+R2) *3.3V = 1,65\nV_delta = V_ref-(3.3V/2) = 0.82 mV\n"
		(exclude_from_sim no)
		(at 72.898 147.066 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "80940002-fe27-4ff7-ba1d-43c1f334cca7")
	)
	(text "Low Pass\n"
		(exclude_from_sim no)
		(at 152.654 84.836 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "c6707e1e-5f54-42d4-99b8-0548c2078622")
	)
	(text_box "Magnetic field from a long straight wire:\n\nB = (mu0 * I) / (2 * pi * r)\n\nGiven:\nI = 1000 A\nr = 1 cm = 0.01 m\nmu0 = 4 * pi * 1e-7\n\n---\n\nCalculation:\nB = (4 * pi * 1e-7 * 1000) / (2 * pi * 0.01)\nB = (4e-4) / 0.02\nB = 2.0e-2 T\n\n---\n\nResult:\nB = 0.02 T = 20 mT"
		(exclude_from_sim no)
		(at 212.09 15.24 0)
		(size 69.85 63.5)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.778 1.778)
			)
			(justify left top)
		)
		(uuid "3e70987b-e258-43bf-81ad-efe8ac81eba6")
	)
